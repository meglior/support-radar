# ==============================================================================
# Секреты и сертификаты (КРИТИЧЕСКИ ВАЖНО)
# ==============================================================================
certs/
*.crt
*.key
*.pem
.env
.env.local
.env.*

# ==============================================================================
# Rust (Cargo) артефакты
# ==============================================================================
# Самое главное — игнорируем папку тяжелых сборок Rust
target/
debug/

# Временные файлы бэкапов форматирования и логи падения компилятора
**/*.rs.bk
rustc-ice-*.txt
**/mutants.out*/

# Файлы отладки Windows (генерируются при сборке Rust на Windows)
*.pdb

# ==============================================================================
# Go артефакты
# ==============================================================================
bin/
# Тестовые бинарники и файлы покрытия кода тестами
*.test
*.out
coverage.*
*.coverprofile
profile.cov

# Ворксрейсы Go (если захочешь использовать локально)
go.work
go.work.sum

# ==============================================================================
# Системные файлы и IDE
# ==============================================================================
*.exe
*.exe~
*.dll
*.so
*.dylib
.DS_Store
Thumbs.db

# Настройки редакторов (опционально, но полезно, чтобы не захламлять реп)
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln